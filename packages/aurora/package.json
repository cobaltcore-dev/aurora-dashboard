{
  "name": "@cobaltcore-dev/aurora",
  "version": "0.16.0",
  "private": false,
  "description": "Aurora OpenStack dashboard — server and client library",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobaltcore-dev/aurora-dashboard.git",
    "directory": "packages/aurora"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/server/index.js",
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "pnpm build:server && pnpm build:client",
    "build:client": "vite build --mode=production",
    "build:server": "tsup",
    "prepublishOnly": "pnpm build",
    "check-i18n": "lingui extract --clean && lingui compile --typescript --verbose",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf .turbo",
    "clean:cache": "rm -rf .turbo",
    "compile": "lingui compile --typescript --verbose",
    "extract": "lingui extract --clean",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "fastify": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/lib-storage": "^3.1042.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@headlessui/react": "^2.2.2",
    "@lingui/core": "^5.9.5",
    "@lingui/react": "^5.9.5",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.4",
    "@tanstack/react-virtual": "^3.13.18",
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "@trpc/server": "11.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify-plugin": "^5.1.0",
    "focus-trap-react": "^12.0.0",
    "node-fetch": "^3.3.2",
    "react-error-boundary": "^6.1.0",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudoperators/juno-ui-components": "9.1.0",
    "@cobaltcore-dev/aurora-config": "workspace:*",
    "@cobaltcore-dev/policy-engine": "workspace:*",
    "@cobaltcore-dev/signal-openstack": "workspace:*",
    "@fastify/vite": "^8.4.1",
    "@lingui/cli": "^5.9.5",
    "@lingui/format-po": "^5.9.5",
    "@lingui/swc-plugin": "^5.11.0",
    "@lingui/vite-plugin": "^5.9.5",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/router-plugin": "^1.167.5",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.2",
    "eslint-plugin-lingui": "^0.13.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.7",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.1",
    "vite-plugin-svgr": "^5.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
