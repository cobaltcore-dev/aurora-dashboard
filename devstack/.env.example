# VM Resources
VM_NAME=devstack
VM_CPUS=4
VM_MEMORY=8G
VM_DISK=40G

# Ubuntu Version (22.04, 24.04, 20.04, or lts for latest)
UBUNTU_VERSION=22.04

# DevStack Version (see VERSIONS.md for all options)
DEVSTACK_VERSION=stable/2025.1

# Networking
PUBLIC_IP=localhost

# Port Forwarding (VM:80 -> Host:HORIZON_PORT, etc.)
HORIZON_PORT=8080
KEYSTONE_PORT=5000
NEUTRON_PORT=9696
NOVA_PORT=8774
GLANCE_PORT=9292
PLACEMENT_PORT=8778

# OpenStack Credentials
ADMIN_PASSWORD=password
DATABASE_PASSWORD=password
RABBIT_PASSWORD=password
SERVICE_PASSWORD=password

# Service Configuration
ENABLE_HORIZON=true
DISABLE_TEMPEST=true
DISABLE_DSTAT=true

# Core Services (always enabled by default):
# - keystone (identity) - Port 5000
# - nova (compute) - Port 8774
# - neutron (networking) - Port 9696
# - glance (image) - Port 9292
# - placement (resource tracking) - Port 8778
# - horizon (dashboard) - Port 80

# Common Optional Services (comma-separated list)
# Enable additional services as needed:
#
# Block Storage:
#   cinder         - Block Storage (persistent volumes) - Port 8776
#
# Object Storage:
#   swift          - Object Storage (S3-like) - Port 8080 (conflicts with Horizon!)
#
# Orchestration:
#   heat           - Orchestration (templates/stacks) - Port 8004
#
# Load Balancer:
#   octavia        - Load Balancing as a Service - Port 9876
#
# DNS:
#   designate      - DNS as a Service - Port 9001
#
# Security:
#   barbican       - Key Management (secrets/certificates) - Port 9311
#
# File Storage:
#   manila         - Shared Filesystems (NFS/CIFS) - Port 8786
#
# Bare Metal:
#   ironic         - Bare Metal Provisioning - Port 6385
#
# Examples:
#   ENABLE_SERVICES=cinder
#   ENABLE_SERVICES=cinder,heat
#   ENABLE_SERVICES=cinder,swift,heat,octavia,designate,barbican
#
ENABLE_SERVICES=

# Port Forwarding for Services (WSL2 only)
# These ports are used for port forwarding from WSL2 to Windows
# You can customize ports if they conflict with other services
#
# Core Services:
HORIZON_PORT=8080       # Dashboard (default 80, mapped to 8080 to avoid sudo)
KEYSTONE_PORT=5000      # Identity
NOVA_PORT=8774          # Compute
NEUTRON_PORT=9696       # Networking
GLANCE_PORT=9292        # Image
PLACEMENT_PORT=8778     # Placement

# Optional Services (only needed if enabled above):
CINDER_PORT=8776        # Block Storage
SWIFT_PORT=8888         # Object Storage (changed from 8080 to avoid conflict!)
HEAT_PORT=8004          # Orchestration API
HEAT_CFN_PORT=8000      # Heat CloudFormation API
OCTAVIA_PORT=9876       # Load Balancer
DESIGNATE_PORT=9001     # DNS
BARBICAN_PORT=9311      # Key Management
MANILA_PORT=8786        # Shared Filesystems
IRONIC_PORT=6385        # Bare Metal
