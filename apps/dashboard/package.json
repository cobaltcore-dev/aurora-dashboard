{
  "name": "@cobaltcore-dev/dashboard",
  "private": true,
  "version": "1.2.5",
  "scripts": {
    "build": "vite build --mode=production",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf .turbo",
    "clean:cache": "rm -rf .turbo",
    "dev": "tsx watch --env-file=.env src/server/server.ts",
    "preview": "NODE_ENV=production tsx --env-file=.env src/server/server.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report --port 3010 --host 0.0.0.0"
  },
  "dependencies": {
    "@cobaltcore-dev/aurora": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fastify/vite": "^8.4.1",
    "@lingui/swc-plugin": "^5.11.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "vite-plugin-static-copy": "4.1.0",
    "vite-plugin-svgr": "^5.2.0"
  }
}
