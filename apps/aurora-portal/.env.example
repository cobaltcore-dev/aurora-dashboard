IDENTITY_ENDPOINT="http://localhost:8080/identity/v3/"
DEFAULT_ENDPOINT_INTERFACE="public"
PORT="4001"
CEPH_S3_ENDPOINT="https://rgw.example.com"
CEPH_REGION="default"

# Ceph Admin API credentials (optional - required for Usage & Quota features)
# Create an admin user in Ceph with read-only capabilities: users=read;usage=read;buckets=read
# CEPH_ADMIN_ACCESS_KEY="your-admin-access-key"
# CEPH_ADMIN_SECRET_KEY="your-admin-secret-key"
IMAGE_METADATA_EXCLUDED_PROPERTIES="name,tags,visibility,protected,min_disk,min_ram,id,status,size,checksum,created_at,updated_at,created-at,updated-at,disk_format,container_format,file,schema,locations,self,direct_url,owner,virtual_size,kernel_id,ramdisk_id,os_hash_algo,os_hash_value,os-hash-algo,os-hash-value,stores,owner_specified.openstack.md5,owner_specified.openstack.sha256,owner_specified.openstack.object"

# mitmproxy configuration for debugging (development mode only)
# Set this to route all OpenStack API calls through mitmproxy
# TLS certificate validation is automatically disabled when using a proxy
# Note: This is IGNORED in production mode for security reasons
# GLOBAL_AGENT_HTTP_PROXY=http://localhost:8888
